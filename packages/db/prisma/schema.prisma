// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PG_DATABASE_URL")
}

// Single-tenant database models for a standalone CRM instance

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // Hashed password
  role      String   @default("user") // admin, manager, user
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // The stateful session token stored in Redis/Cookie
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ==========================================
// Core CRM Models
// ==========================================

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  status    String   @default("Active") // Active, Inactive, Lead
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supportTickets SupportTicket[]
  realEstateViewings RealEstateViewing[]
  realEstateOffers   RealEstateOffer[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts  Contact[]
  deals     Deal[]
  invoices  Invoice[]
}

model Deal {
  id                String   @id @default(cuid())
  title             String
  amount            Float
  stage             String   // Lead, Qualification, Proposal, Won, Lost
  expectedCloseDate DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId         String?
  company           Company? @relation(fields: [companyId], references: [id])
}

// ==========================================
// Extra Modules: Real Estate
// ==========================================

model RealEstateAgent {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  role      String   // Broker, Buying Agent, Listing Agent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  RealEstateListing[]
  viewings  RealEstateViewing[]
}

model RealEstateListing {
  id          String   @id @default(cuid())
  title       String
  price       Float
  beds        Int
  baths       Float
  status      String   @default("Active") // Active, Pending, Sold
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentId     String
  agent       RealEstateAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  viewings    RealEstateViewing[]
  offers      RealEstateOffer[]
}

// ==========================================
// Extra Modules: Ticketing
// ==========================================

model SupportTicket {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("Open") // Open, In Progress, Resolved
  priority    String   @default("Normal") // Low, Normal, High
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
}

// ==========================================
// Extra Modules: Invoicing
// ==========================================

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  amount        Float
  status        String   @default("Draft") // Draft, Sent, Paid, Overdue
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
}

model RealEstateViewing {
  id          String   @id @default(cuid())
  scheduledAt DateTime
  status      String   @default("Scheduled") // Scheduled, Completed, Cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listingId   String
  listing     RealEstateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  agentId     String
  agent       RealEstateAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model RealEstateOffer {
  id            String   @id @default(cuid())
  amount        Float
  status        String   @default("Pending") // Pending, Accepted, Rejected
  contingencies String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listingId     String
  listing       RealEstateListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  contactId     String
  contact       Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
