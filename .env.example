# ─── Server ──────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# ─── PostgreSQL ──────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=xapps
PG_PASSWORD=
PG_DATABASE=xapps_dev

# ─── MongoDB (optional, used by some modules) ─
MONGO_URI=mongodb://localhost:27017/xapps_dev

# ─── Redis (sessions, cache, queues) ─────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth Providers (optional) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── File Storage ────────────────────────────
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Email ───────────────────────────────────
EMAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
